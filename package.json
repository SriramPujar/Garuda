{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "description": "Garuda AI - Your Spiritual Intellectual Guide",
  "author": "Sriram Pujar",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma db push --accept-data-loss && next build",
    "start": "next start",
    "lint": "eslint",
    "ingest": "node --max-old-space-size=4096 scripts/ingest.js",
    "ingest-cloud": "node scripts/ingest-cloud.js",
    "build:pc": "electron-builder -w",
    "start:pc": "electron electron/main.js",
    "build:android": "node scripts/build-android.js",
    "postinstall": "prisma generate"
  },
  "build": {
    "appId": "com.garuda.ai",
    "productName": "Garuda AI",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asar": false,
    "directories": {
      "output": "garuda_dist"
    },
    "win": {
      "icon": "electron/icon.png",
      "target": "nsis"
    }
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.46",
    "@ai-sdk/groq": "^2.0.33",
    "@ai-sdk/react": "^2.0.115",
    "@capacitor/app": "^8.1.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@prisma/client": "^5.20.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "ai": "^5.0.113",
    "bcryptjs": "^3.0.3",
    "next": "^14.2.24",
    "next-auth": "^4.24.13",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8",
    "eslint-config-next": "^14.2.24",
    "prisma": "^5.20.0",
    "typescript": "^5"
  }
}
